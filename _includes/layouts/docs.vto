<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title>{{ site_title }}{{ if title }} - {{ title }}{{ /if }}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/custom.css">
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  <script src="/pagefind/pagefind-ui.js"></script>
  <script>
    (function(){var t=localStorage.getItem("theme")||(matchMedia("(prefers-color-scheme:dark)").matches?"dark":"light");document.documentElement.setAttribute("data-theme",t)})();
  </script>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site_title }}">
  <meta property="og:title" content="{{ title }}">
  {{ if description }}<meta property="og:description" content="{{ description }}">
  <meta name="description" content="{{ description }}">{{ /if }}
  <meta property="og:url" content="{{ site_url }}{{ url }}">
</head>
<body>

  <div class="header">
    <div class="header-inner">
      <div class="header-left">
        <button class="sidebar-toggle" aria-label="Toggle sidebar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <a class="site-title-trigger" href="/">
          <img class="logo-light" src="/assets/img/strike48-logo.svg" alt="{{ site_title }}">
          <img class="logo-dark" src="/assets/img/strike48-logo-light.svg" alt="{{ site_title }}">
        </a>
      </div>
      <div class="header-right">
        {{ for link of nav_links }}
        <a class="social-link" href="{{ link.url }}" title="{{ link.title }}" target="_blank" rel="noopener">
          {{ if link.title == "GitHub" }}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>{{ else if link.title == "Discord" }}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg>{{ /if }}
        </a>
        {{ /for }}
        <button class="theme-toggle" aria-label="Toggle theme">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="docs-layout">
    <nav class="sidebar">
      <div id="pagefind-search"></div>
      {{ include "partials/sidebar.vto" }}
    </nav>

    <main class="docs-content">
      {{ if title }}<h1 class="page-title">{{ title }}</h1>{{ /if }}
      {{ if type == "blog" }}
      <div class="blog-meta">
        {{ if date }}{{ set d = (date instanceof Date) ? date : new Date(date) }}<time datetime="{{ d.toISOString().split('T')[0] }}">{{ d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) }}</time>{{ /if }}
        {{ if authors && author_info }}
          {{ for id of authors }}
            {{ set author = author_info[id] }}
            {{ if author }}
            <span style="display:inline-flex;align-items:center;gap:0.35rem">
              {{ if author.picture }}<img src="{{ author.picture }}" alt="{{ author.title || author.name }}" style="width:1.5rem;height:1.5rem;border-radius:50%">{{ /if }}
              {{ author.title || author.name }}
            </span>
            {{ /if }}
          {{ /for }}
        {{ /if }}
      </div>
      {{ /if }}
      <article>{{ content }}</article>
    </main>

    <aside class="toc">
      <nav class="toc-nav" data-toc></nav>
    </aside>
  </div>

  <div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Cookie consent">
    <div class="cookie-inner">
      <p class="cookie-text">
        This website stores cookies on your computer to collect information about how you interact with our website. We use this information to customize content and analyze traffic. See our <a href="/legal/privacy-policy/">Cookie Policy</a>.
      </p>
      <p class="cookie-text cookie-text-small">
        If you decline, your information won't be tracked. A single cookie will remember your preference.
      </p>
      <div class="cookie-actions">
        <button id="cookie-accept" class="cookie-btn cookie-btn-accept">Accept</button>
        <button id="cookie-decline" class="cookie-btn cookie-btn-decline">Decline</button>
      </div>
    </div>
  </div>

  <script src="/assets/js/theme-switcher.js"></script>
  <script src="/assets/js/sidebar-toggle.js"></script>
  <script src="/assets/js/cookie-consent.js"></script>
  <script>new PagefindUI({element:"#pagefind-search",showSubResults:true,showImages:false});</script>
  <script>
    document.querySelectorAll(".sidebar a[aria-current='page']").forEach(function(a){
      var d=a.closest("details");while(d){d.open=true;d=d.parentElement.closest("details")}
    });
  </script>
</body>
</html>
