---
title: Blog
description: Product updates, engineering insights, and guides from the Strike48 team.
nav_order: 0
parent: "Blog"
type: blog-index
templateEngine: njk
---

<p>Product updates, engineering insights, and guides from the Strike48 team.</p>

{% set posts = search.pages("type=blog", "date=desc") %}

{% for post in posts %}
{% if post.url != url %}
<article style="margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--muted-border-color, #e0e0e0);">
  <h2 style="margin-bottom: 0.25rem;"><a href="{{ post.url }}">{{ post.title }}</a></h2>
  <p style="margin: 0.25rem 0; opacity: 0.7; font-size: 0.9em; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
    <time datetime="{{ post.date | date('DATE') }}">{{ post.date | date('HUMAN_DATE') }}</time>
    {% if post.authors %}
      <span style="opacity:0.5">&middot;</span>
      {% for author_id in post.authors %}
        {% set author = author_info[author_id] %}
        {% if author %}
          <span style="display:inline-flex;align-items:center;gap:0.35rem;">
            {% if author.picture %}<img src="{{ author.picture }}" alt="{{ author.title or author.name }}" style="width:1.5rem;height:1.5rem;border-radius:50%;">{% endif %}
            {{ author.title or author.name }}
          </span>
        {% else %}{{ author_id }}{% endif %}{% if not loop.last %}, {% endif %}
      {% endfor %}
    {% endif %}
  </p>
  {% if post.excerpt %}
  <p>{{ post.excerpt }}</p>
  {% endif %}
</article>
{% endif %}
{% endfor %}
